    "@livekit/components-core": "^0.11.10",
    "@livekit/components-react": "^2.6.9",
    "@livekit/protocol": "^1.23.0",
    "@livekit/track-processors": "workspace:*",
    "@m-lab/ndt7": "^0.0.6",
    "@mui/material": "^6.4.7",
    "@mui/x-date-pickers": "^6.20.2",
    "@opentalk/fluent_conv": "workspace:*",
    "@opentalk/i18next-fluent": "workspace:*",
    "@opentalk/redux-oidc": "workspace:*",
