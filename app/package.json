{
  "name": "@opentalk/opentalk",
  "version": "2.3.0-alpha",
  "description": "Frontend for the OpenTalk video chat solution",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src/ --fix",
    "start": "pnpm run create:dev && vite",
    "start:hot": "pnpm run create:dev && HMR=true vite",
    "build": "pnpm run create:dev && vite build",
    "build:profiling": "pnpm run create:dev && BUILD_PATH=../dist-profiling vite build --mode profiling",
    "create:dev": "node -e \"require('fs').writeFile('tsconfig.json', fs.readFileSync('tsconfig.dev.json'), function(err) { if (err) console.log(err); console.log('File successfully created from tsconfig.dev.json!') })\""
  },
  "dependencies": {
    "@date-io/date-fns": "^2.15.0",
