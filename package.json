{
  "name": "@opentalk/monorepo",
  "version": "2.9.0-dev",
  "description": "OpenTalk Monorepo",
  "private": true,
  "scripts": {
    "lint": "eslint --max-warnings 0 --no-warn-ignored",
    "lint:pre-commit": "pnpm lint",
    "fmt": "prettier --write \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:ci": "prettier --check \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:pre-commit": "prettier --check",
    "typecheck": "tsc --build --noEmit",
    "deps:circular": "madge --circular .",
    "deps:unused": "knip --include dependencies,files",
    "start": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' start",
    "start:hot": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' start:hot",
    "watch": "pnpm run -r watch",
    "build": "pnpm run -r build",
    "build:libs": "del-cli packages/**/*/dist && pnpm --filter './packages/**' run build",
    "build:profiling": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' build:profiling",
    "docker:prod": "pnpm build && docker build -f ./ci/Dockerfile -t web-app:local .",
    "docker:profiling": "pnpm build:profiling && docker build -f ./ci/Dockerfile --build-arg DIST_FOLDER=dist-profiling -t web-app:local-profiling .",
    "test:unit": "pnpm build:libs && vitest run",
    "test:unit:watch": "pnpm build:libs && vitest watch",
    "test:unit:ci": "pnpm build:libs && vitest run --coverage --no-cache --silent",
    "test:unit:ide": "vitest run",
    "clean": "del-cli app/node_modules packages/**/*/node_modules dist/app node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "knip": "^6.7.0",
    "licensee": "^12.0.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.33.2"
}
