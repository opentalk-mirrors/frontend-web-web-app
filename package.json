{
  "name": "@opentalk/monorepo",
  "version": "2.6.0-alpha",
  "description": "OpenTalk Monorepo",
  "private": true,
  "scripts": {
    "lint": "eslint --max-warnings 0",
    "lint:pre-commit": "pnpm lint",
    "fmt": "prettier --write \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:ci": "prettier --check \"./*.{js,ts,jsx,tsx}\" \"./**/*.{js,ts,jsx,tsx}\"",
    "fmt:pre-commit": "prettier --check",
    "typecheck": "tsc --build",
    "deps:circular": "madge --circular .",
    "deps:unused": "knip --include dependencies,files",
    "start": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' start",
    "start:hot": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' start:hot",
    "watch": "pnpm run -r watch",
    "build": "pnpm run -r build",
    "build:libs": "pnpm --filter './packages/**' run build",
    "build:profiling": "pnpm build:libs && pnpm --filter '@opentalk/opentalk' build:profiling",
    "docker:prod": "pnpm build && docker build -f ./ci/Dockerfile -t web-app:local .",
    "docker:profiling": "pnpm build:profiling && docker build -f ./ci/Dockerfile --build-arg DIST_FOLDER=dist-profiling -t web-app:local-profiling .",
    "test:unit": "pnpm build:libs && jest",
    "test:unit:watch": "pnpm build:libs && jest --watchAll",
    "test:unit:ci": "pnpm build:libs && jest --coverage --no-cache --silent --ci",
    "test:unit:ide": "jest",
    "test:e2e": "npx playwright test --config playwright.config.ts",
    "clean": "del-cli app/node_modules packages/**/*/node_modules dist/app node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.53.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/babel__preset-env": "^7.10.0",
    "@types/node": "^22.15.31",
    "babel-plugin-inline-react-svg": "^2.0.2",
    "babel-preset-vite": "^1.1.3",
    "del-cli": "^6.0.0",
    "dotenv": "^16.5.0",
    "eslint": "^9.29.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-refresh": "^0.4.20",
    "fast-xml-parser": "^5.2.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jest-cli": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fixed-jsdom": "^0.0.9",
    "jest-junit": "^16.0.0",
    "knip": "^5.61.1",
    "licensee": "^11.1.1",
    "lint-staged": "^16.1.0",
    "madge": "^8.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.1"
  },
  "packageManager": "pnpm@10.11.1"
}
