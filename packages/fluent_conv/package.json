{
  "name": "@opentalk/fluent_conv",
  "version": "1.0.0",
  "description": "Updated fluent2js and js2fluent converter",
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/main.cjs",
  "module": "dist/main.js",
  "exports": {
    ".": {
      "import": "./dist/main.js",
      "require": "./dist/main.cjs"
    }
  },
  "types": "dist/types.d.ts",
  "dependencies": {
    "@fluent/syntax": "0.19.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vite-plugin-dts": "^4.5.3"
  },
  "scripts": {
    "watch": "vite build --watch",
    "build": "vite build"
  },
  "keywords": [
    "fluent",
    "projectfluent",
    "json",
    "js",
    "translation",
    "converter"
  ],
  "author": "jamuhl",
  "license": "MIT",
  "contributors": [
    "Rudi Floren <r.floren@heinlein-video.de>"
  ],
  "files": [
    "src/**"
  ],
  "eslintConfig": {
    "extends": [
      "prettier"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
