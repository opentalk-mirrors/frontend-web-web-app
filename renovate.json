{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "rangeStrategy": "bump",
  "reviewers": [
    "@opentalk/tools/renovate-reviewers/frontend"
  ],
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackagePatterns": [
        "@fluent/*"
      ],
      "groupName": "fluent",
      "groupSlug": "fluent"
    },
    {
      "matchPackagePatterns": [
        "eslint*"
      ],
      "groupName": "eslint-plugins",
      "groupSlug": "eslint-plugins"
    },
    {
      "matchPackagePatterns": [
        "@rollup*",
        "rollup"
      ],
      "groupName": "rollup",
      "groupSlug": "rollup"
    },
    {
      "matchPackagePatterns": [
        "uuid",
        "@types/uuid"
      ],
      "groupName": "uuid",
      "groupSlug": "uuid"
    },
    {
      "matchPackagePatterns": [
        "react-window",
        "@types/react-window"
      ],
      "groupName": "react-window",
      "groupSlug": "react-window"
    },
    {
      "matchPackagePatterns": [
        "fscreen",
        "@types/fscreen"
      ],
      "groupName": "fscreen",
      "groupSlug": "fscreen"
    },
    {
      "matchPackagePatterns": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ],
      "groupName": "react",
      "groupSlug": "react"
    },
    {
      "matchPackagePatterns": [
        "lodash",
        "@types/lodash"
      ],
      "groupName": "lodash",
      "groupSlug": "lodash"
    },
    {
      "matchPackagePatterns": [
        "@types/*"
      ],
      "groupName": "@types",
      "groupSlug": "@types"
    },
    {
      "matchPackagePatterns": [
        "^i18next"
      ],
      "groupName": "i18next",
      "groupSlug": "i18next"
    },
    {
      "matchPackagePatterns": [
        "^livekit",
        "^@livekit"
      ],
      "groupName": "livekit",
      "groupSlug": "livekit"
    }
  ]
}
